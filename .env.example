# Ollama is on by default.
# Native dev defaults to http://localhost:11434.
# Docker compose defaults to http://host.docker.internal:11434.
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible APIs
# OPENAI_ENABLED=true
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...

# Optional
# MODEL_CAPABILITY_PROBE=true
